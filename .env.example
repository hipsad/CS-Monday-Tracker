# Copy this file to .env and fill in your values

# Leetify API Key (required for fetching player stats)
# Find yours at https://leetify.com/app/settings
LEETIFY_API_KEY=your_leetify_api_key_here

# OpenAI API Key (optional - needed for AI analysis features)
OPENAI_API_KEY=your_openai_api_key_here

# Flask secret key (change this to a random string)
SECRET_KEY=change-me-to-a-random-secret

# Database path (defaults to tracker.db in the project root)
DATABASE_URL=sqlite:///tracker.db

# Flask environment
FLASK_ENV=development
